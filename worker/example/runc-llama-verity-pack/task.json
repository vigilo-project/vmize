{
  "name": "runc-llama-verity-pack",
  "description": "Convert handed-off rootfs into squashfs+dm-verity artifacts and pass through model/config for the runtime verification stage",
  "disk_size": "20G",
  "vm": {
    "boot": "custom",
    "kernel": "../../../image/bzImage",
    "rootfs": "../../../image/rootfs.qcow2",
    "kernel_config": "../../../image/kernel.config",
    "required_kernel_config": [
      "CONFIG_BLK_DEV_LOOP=y"
    ],
    "clone_rootfs": true
  },
  "commands": [
    "00_bootstrap.sh",
    "10_make_verity.sh"
  ],
  "artifacts": [
    "rootfs.squashfs",
    "rootfs.verity",
    "rootfs.root_hash",
    "model.gguf",
    "config.json"
  ],
  "next_task_dir": "../runc-llama-verity-run"
}
