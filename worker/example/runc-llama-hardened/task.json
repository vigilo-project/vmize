{
  "name": "runc-llama-hardened",
  "description": "Consume rootfs/config/model artifacts, produce hardened OCI config for UDS-only communication, and prepare capability-minimized runtime settings",
  "disk_size": "20G",
  "vm": {
    "boot": "custom",
    "kernel": "../../../image/bzImage",
    "rootfs": "../../../image/rootfs.qcow2",
    "kernel_config": "../../../image/kernel.config",
    "required_kernel_config": [
      "CONFIG_USER_NS=y",
      "CONFIG_CGROUP_BPF=y",
      "CONFIG_CGROUP_DEVICE=y"
    ],
    "clone_rootfs": true
  },
  "commands": [
    "00_bootstrap.sh",
    "10_minimize_config.sh"
  ],
  "artifacts": [
    "rootfs",
    "config.json",
    "model.gguf",
    "config.min.json",
    "removed-caps.txt",
    "cap-summary.txt",
    "llama-answer.txt"
  ],
  "next_task_dir": "../runc-llama-verity-pack"
}
