{
  "name": "runc-llama-build",
  "description": "Build llama.cpp on runc and validate guest-to-container HTTP prompt flow; then hand off rootfs/config/model artifacts to the hardened UDS stage",
  "disk_size": "20G",
  "vm": {
    "boot": "custom",
    "kernel": "../../../image/bzImage",
    "rootfs": "../../../image/rootfs.qcow2",
    "kernel_config": "../../../image/kernel.config",
    "required_kernel_config": [
      "CONFIG_USER_NS=y",
      "CONFIG_CGROUP_BPF=y",
      "CONFIG_CGROUP_DEVICE=y"
    ],
    "clone_rootfs": true
  },
  "commands": [
    "00_bootstrap.sh",
    "10_build_bundle.sh",
    "20_run_basic.sh",
    "30_verify.sh"
  ],
  "artifacts": [
    "rootfs",
    "config.json",
    "model.gguf",
    "llama-answer.txt"
  ],
  "next_task_dir": "../runc-llama-hardened"
}
