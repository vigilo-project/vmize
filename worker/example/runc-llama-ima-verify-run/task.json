{
  "name": "runc-llama-ima-verify-run",
  "description": "Verify IMA-signed runtime tar with cert.der, then run llama on dm-verity rootfs and validate UDS inference",
  "disk_size": "20G",
  "vm": {
    "boot": "custom",
    "kernel": "../../../image/bzImage",
    "rootfs": "../../../image/rootfs.qcow2",
    "clone_rootfs": true
  },
  "commands": [
    "00_bootstrap.sh",
    "10_verify_and_run.sh"
  ],
  "artifacts": [
    "llama-answer.txt",
    "llama-error.txt",
    "llama-server.log",
    "runtime-summary.txt",
    "runc-list.txt",
    "prompt.txt",
    "ima-verify.log"
  ]
}
